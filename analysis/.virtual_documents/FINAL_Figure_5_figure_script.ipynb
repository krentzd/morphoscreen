    thresh_list.append(np.max(np.unique(adj_matrix[i])))

thresh = math.floor(min(thresh_list) * 100) / 100

mask = sim_matrix > thresh
adjacency_matrix = sim_matrix * mask
np.fill_diagonal(adjacency_matrix, 0)


